<%- include('../../partials/header') %>
<%- include('../../partials/navbar') %>

<div class="container my-5" style="max-width: 750px;">
  <!-- Tombol Kembali -->
  <div class="mb-4">
    <a href="/admin/cars" class="btn btn-secondary-custom btn-sm">
      <i class="fa-solid fa-arrow-left me-2"></i> Kembali ke Daftar Mobil
    </a>
  </div>

  <!-- Form Card -->
  <div class="glass-card p-4 p-md-5 shadow-lg">
    <h3 class="text-white font-outfit font-weight-bold mb-1">Tambah Unit Mobil</h3>
    <p class="text-muted small mb-4">Daftarkan armada mobil baru ke dalam sistem rental katalog</p>
    <hr class="text-secondary opacity-25 mb-4">

    <!-- Notifikasi Error -->
    <% if (error) { %>
      <div class="alert alert-danger alert-dismissible fade show border-0 d-flex align-items-center mb-4 shadow" role="alert" style="background-color: rgba(239, 68, 68, 0.15); color: #f87171; border-radius: 8px;">
        <i class="fa-solid fa-triangle-exclamation me-2 fs-5"></i>
        <div class="small"><%= error %></div>
        <button type="button" class="btn-close btn-close-white ms-auto" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    <% } %>

    <!-- Form Input Data Mobil -->
    <form action="/admin/cars/add" method="POST" enctype="multipart/form-data">
      <div class="row">
        <!-- Input Nama Mobil -->
        <div class="col-md-6 mb-3">
          <label for="nama_mobil" class="form-label text-muted small fw-bold">Nama Mobil</label>
          <input type="text" class="form-control form-control-custom" id="nama_mobil" name="nama_mobil" placeholder="Contoh: Avanza Veloz" required>
        </div>
        
        <!-- Input Merek -->
        <div class="col-md-6 mb-3">
          <label for="merek" class="form-label text-muted small fw-bold">Merek Mobil</label>
          <input type="text" class="form-control form-control-custom" id="merek" name="merek" placeholder="Contoh: Toyota" required>
        </div>
      </div>

      <div class="row">
        <!-- Input Tahun -->
        <div class="col-md-6 mb-3">
          <label for="tahun" class="form-label text-muted small fw-bold">Tahun Rilis</label>
          <input type="number" class="form-control form-control-custom" id="tahun" name="tahun" min="2000" max="2035" placeholder="Contoh: 2022" required>
        </div>
        
        <!-- Input Harga -->
        <div class="col-md-6 mb-3">
          <label for="harga_per_hari" class="form-label text-muted small fw-bold">Tarif Sewa Per Hari (IDR)</label>
          <input type="number" class="form-control form-control-custom" id="harga_per_hari" name="harga_per_hari" min="1000" placeholder="Contoh: 350000" required>
        </div>
      </div>

      <div class="row">
        <!-- Input Gambar File -->
        <div class="col-md-6 mb-3">
          <label for="gambar" class="form-label text-muted small fw-bold">Gambar Kendaraan</label>
          <input type="file" class="form-control form-control-custom" id="gambar" name="gambar" accept="image/*">
          <div class="form-text text-muted" style="font-size: 0.72rem;">* Format didukung: png, jpg, jpeg, webp. Maksimal 3MB.</div>
        </div>

        <!-- Input Status Awal -->
        <div class="col-md-6 mb-4">
          <label for="status" class="form-label text-muted small fw-bold">Status Awal</label>
          <select name="status" id="status" class="form-select form-control-custom" style="cursor: pointer;">
            <option value="Tersedia" selected>Tersedia</option>
            <option value="Tidak Tersedia">Tidak Tersedia</option>
          </select>
        </div>
      </div>

      <button type="submit" class="btn btn-primary-custom w-100 py-2.5 mt-2">
        <i class="fa-solid fa-save me-2"></i> Daftarkan Mobil Baru
      </button>
    </form>
  </div>
</div>

<%- include('../../partials/footer') %>
