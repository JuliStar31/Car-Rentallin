<%- include('../../partials/header') %>
<%- include('../../partials/navbar') %>

<div class="container my-5">
  <div class="row align-items-center mb-5">
    <div class="col-md-8">
      <h2 class="mb-1 text-white font-outfit font-weight-bold">Kelola Armada Mobil</h2>
      <p class="text-muted mb-0">Tambah unit baru, perbarui tarif sewa, atau hapus kendaraan dari sistem catalog</p>
    </div>
    <div class="col-md-4 text-md-end mt-3 mt-md-0">
      <a href="/admin/cars/add" class="btn btn-primary-custom">
        <i class="fa-solid fa-plus-circle me-2"></i> Tambah Mobil Baru
      </a>
    </div>
  </div>

  <!-- Alert Banner -->
  <% if (error) { %>
    <div class="alert alert-danger alert-dismissible fade show border-0 d-flex align-items-center mb-4 shadow" role="alert" style="background-color: rgba(239, 68, 68, 0.15); color: #f87171; border-radius: 8px;">
      <i class="fa-solid fa-circle-exclamation me-2 fs-5"></i>
      <div class="small"><%= error %></div>
      <button type="button" class="btn-close btn-close-white ms-auto" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
  <% } %>

  <% if (success) { %>
    <div class="alert alert-success alert-dismissible fade show border-0 d-flex align-items-center mb-4 shadow" role="alert" style="background-color: rgba(16, 185, 129, 0.15); color: #34d399; border-radius: 8px;">
      <i class="fa-solid fa-circle-check me-2 fs-5"></i>
      <div class="small"><%= success %></div>
      <button type="button" class="btn-close btn-close-white ms-auto" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
  <% } %>

  <!-- Tabel CRUD Mobil -->
  <div class="table-responsive-custom shadow-lg">
    <table class="table table-custom mb-0">
      <thead>
        <tr>
          <th>ID Mobil</th>
          <th>Cover Gambar</th>
          <th>Nama Mobil</th>
          <th>Merek</th>
          <th class="text-center">Tahun Rilis</th>
          <th class="text-end">Tarif / Hari</th>
          <th class="text-center">Ketersediaan</th>
          <th class="text-center">Aksi Operasi</th>
        </tr>
      </thead>
      <tbody>
        <% if (cars && cars.length > 0) { %>
          <% cars.forEach(car => { %>
            <tr>
              <td>
                <span class="text-white font-outfit font-weight-bold">#CAR-<%= car.id %></span>
              </td>
              <td>
                <img src="/uploads/<%= car.gambar %>" alt="<%= car.nama_mobil %>" class="rounded shadow-sm" style="width: 75px; height: 48px; object-fit: cover; border: 1px solid var(--card-border);" onerror="this.src='/uploads/default-car.jpg'">
              </td>
              <td class="text-white font-weight-bold"><%= car.nama_mobil %></td>
              <td class="text-muted"><%= car.merek %></td>
              <td class="text-center text-white"><%= car.tahun %></td>
              <td class="text-end text-white font-weight-bold font-outfit">
                <%= new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR', minimumFractionDigits: 0 }).format(car.harga_per_hari) %>
              </td>
              <td class="text-center">
                <% if (car.status === 'Tersedia') { %>
                  <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 px-3 py-1.5 rounded-pill" style="font-size: 0.75rem;"><i class="fa-solid fa-circle-check me-1 small"></i> Tersedia</span>
                <% } else { %>
                  <span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 px-3 py-1.5 rounded-pill" style="font-size: 0.75rem;"><i class="fa-solid fa-ban me-1 small"></i> Tersewa</span>
                <% } %>
              </td>
              <td class="text-center">
                <a href="/admin/cars/edit/<%= car.id %>" class="btn btn-secondary-custom btn-sm py-1.5 px-3 me-1">
                  <i class="fa-regular fa-pen-to-square me-1"></i> Edit
                </a>
                <a href="/admin/cars/delete/<%= car.id %>" class="btn btn-danger-custom btn-sm py-1.5 px-3" onclick="return confirm('Apakah Anda yakin ingin menghapus data mobil <%= car.nama_mobil %>? Seluruh riwayat transaksi sewa unit ini akan terhapus otomatis.')">
                  <i class="fa-solid fa-trash me-1"></i> Hapus
                </a>
              </td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr>
            <td colspan="8" class="text-center py-5 text-muted">
              <div class="d-inline-flex align-items-center justify-content-center bg-secondary bg-opacity-10 text-muted rounded-circle mb-3" style="width: 60px; height: 60px;">
                <i class="fa-solid fa-car-rear fs-3"></i>
              </div>
              <p class="mb-3">Belum ada armada mobil yang didaftarkan ke sistem.</p>
              <a href="/admin/cars/add" class="btn btn-primary-custom btn-sm">
                <i class="fa-solid fa-plus-circle me-1"></i> Tambah Mobil Sekarang
              </a>
            </td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<%- include('../../partials/footer') %>
