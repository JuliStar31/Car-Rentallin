<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="auth-wrapper">
  <div class="glass-card auth-card shadow-lg">
    <div class="text-center mb-4">
      <div class="d-inline-flex align-items-center justify-content-center bg-primary bg-opacity-10 text-primary rounded-circle mb-3" style="width: 60px; height: 60px;">
        <i class="fa-solid fa-lock-open fs-3 text-info"></i>
      </div>
      <h3 class="mb-1 font-outfit text-white font-weight-bold">Selamat Datang</h3>
      <p class="text-muted small">Silakan masuk untuk mulai memesan mobil impian Anda</p>
    </div>
    
    <!-- Notifikasi Alert -->
    <% if (error) { %>
      <div class="alert alert-danger alert-dismissible fade show border-0 d-flex align-items-center" role="alert" style="background-color: rgba(239, 68, 68, 0.15); color: #f87171; border-radius: 8px;">
        <i class="fa-solid fa-triangle-exclamation me-2"></i>
        <div class="small"><%= error %></div>
        <button type="button" class="btn-close btn-close-white ms-auto" data-bs-dismiss="alert" aria-label="Close" style="font-size: 0.75rem; padding: 1rem;"></button>
      </div>
    <% } %>

    <% if (success) { %>
      <div class="alert alert-success alert-dismissible fade show border-0 d-flex align-items-center" role="alert" style="background-color: rgba(16, 185, 129, 0.15); color: #34d399; border-radius: 8px;">
        <i class="fa-solid fa-circle-check me-2"></i>
        <div class="small"><%= success %></div>
        <button type="button" class="btn-close btn-close-white ms-auto" data-bs-dismiss="alert" aria-label="Close" style="font-size: 0.75rem; padding: 1rem;"></button>
      </div>
    <% } %>

    <form action="/auth/login" method="POST">
      <div class="mb-3">
        <label for="username" class="form-label text-muted small">Username</label>
        <div class="input-group">
          <span class="input-group-text border-0 ps-3 pe-0" style="background-color: rgba(17, 24, 39, 0.8); color: #6b7280;">
            <i class="fa-solid fa-user"></i>
          </span>
          <input type="text" class="form-control form-control-custom ps-3" id="username" name="username" placeholder="Masukkan username Anda" required>
        </div>
      </div>

      <div class="mb-4">
        <label for="password" class="form-label text-muted small">Password</label>
        <div class="input-group">
          <span class="input-group-text border-0 ps-3 pe-0" style="background-color: rgba(17, 24, 39, 0.8); color: #6b7280;">
            <i class="fa-solid fa-key"></i>
          </span>
          <input type="password" class="form-control form-control-custom ps-3" id="password" name="password" placeholder="Masukkan password Anda" required>
        </div>
      </div>

      <button type="submit" class="btn btn-primary-custom w-100 py-2.5 mb-3">
        <i class="fa-solid fa-right-to-bracket me-2"></i> Masuk ke Sistem
      </button>
      
      <div class="text-center">
        <span class="text-muted small">Belum terdaftar? <a href="/auth/register" class="text-info text-decoration-none font-weight-bold">Buat Akun Baru</a></span>
      </div>
    </form>
  </div>
</div>

<%- include('../partials/footer') %>
