<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="auth-wrapper">
  <div class="glass-card auth-card shadow-lg">
    <div class="text-center mb-4">
      <div class="d-inline-flex align-items-center justify-content-center bg-primary bg-opacity-10 text-primary rounded-circle mb-3" style="width: 60px; height: 60px;">
        <i class="fa-solid fa-user-plus fs-3 text-info"></i>
      </div>
      <h3 class="mb-1 font-outfit text-white font-weight-bold">Daftar Akun Baru</h3>
      <p class="text-muted small">Lengkapi formulir di bawah ini untuk bergabung</p>
    </div>

    <!-- Notifikasi Alert -->
    <% if (error) { %>
      <div class="alert alert-danger alert-dismissible fade show border-0 d-flex align-items-center" role="alert" style="background-color: rgba(239, 68, 68, 0.15); color: #f87171; border-radius: 8px;">
        <i class="fa-solid fa-triangle-exclamation me-2"></i>
        <div class="small"><%= error %></div>
        <button type="button" class="btn-close btn-close-white ms-auto" data-bs-dismiss="alert" aria-label="Close" style="font-size: 0.75rem; padding: 1rem;"></button>
      </div>
    <% } %>

    <form action="/auth/register" method="POST">
      <div class="mb-3">
        <label for="nama_lengkap" class="form-label text-muted small">Nama Lengkap</label>
        <div class="input-group">
          <span class="input-group-text border-0 ps-3 pe-0" style="background-color: rgba(17, 24, 39, 0.8); color: #6b7280;">
            <i class="fa-solid fa-id-card"></i>
          </span>
          <input type="text" class="form-control form-control-custom ps-3" id="nama_lengkap" name="nama_lengkap" placeholder="Contoh: Budi Setiawan" required>
        </div>
      </div>

      <div class="mb-3">
        <label for="email" class="form-label text-muted small">Alamat Email</label>
        <div class="input-group">
          <span class="input-group-text border-0 ps-3 pe-0" style="background-color: rgba(17, 24, 39, 0.8); color: #6b7280;">
            <i class="fa-solid fa-envelope"></i>
          </span>
          <input type="email" class="form-control form-control-custom ps-3" id="email" name="email" placeholder="Contoh: budi@gmail.com" required>
        </div>
      </div>

      <div class="mb-3">
        <label for="username" class="form-label text-muted small">Username</label>
        <div class="input-group">
          <span class="input-group-text border-0 ps-3 pe-0" style="background-color: rgba(17, 24, 39, 0.8); color: #6b7280;">
            <i class="fa-solid fa-user"></i>
          </span>
          <input type="text" class="form-control form-control-custom ps-3" id="username" name="username" placeholder="Buat username baru" required>
        </div>
      </div>

      <div class="mb-3">
        <label for="no_telepon" class="form-label text-muted small">Nomor Telepon / WA</label>
        <div class="input-group">
          <span class="input-group-text border-0 ps-3 pe-0" style="background-color: rgba(17, 24, 39, 0.8); color: #6b7280;">
            <i class="fa-solid fa-phone"></i>
          </span>
          <input type="text" class="form-control form-control-custom ps-3" id="no_telepon" name="no_telepon" placeholder="Contoh: 089876543210" required>
        </div>
      </div>

      <div class="row">
        <div class="col-md-6 mb-3">
          <label for="password" class="form-label text-muted small">Password</label>
          <div class="input-group">
            <span class="input-group-text border-0 ps-3 pe-0" style="background-color: rgba(17, 24, 39, 0.8); color: #6b7280;">
              <i class="fa-solid fa-key"></i>
            </span>
            <input type="password" class="form-control form-control-custom ps-3" id="password" name="password" placeholder="Minimal 6 karakter" required>
          </div>
        </div>
        <div class="col-md-6 mb-3">
          <label for="confirm_password" class="form-label text-muted small">Konfirmasi Password</label>
          <div class="input-group">
            <span class="input-group-text border-0 ps-3 pe-0" style="background-color: rgba(17, 24, 39, 0.8); color: #6b7280;">
              <i class="fa-solid fa-check-double"></i>
            </span>
            <input type="password" class="form-control form-control-custom ps-3" id="confirm_password" name="confirm_password" placeholder="Ulangi password" required>
          </div>
        </div>
      </div>

      <button type="submit" class="btn btn-primary-custom w-100 py-2.5 mb-3 mt-2">
        <i class="fa-solid fa-user-plus me-2"></i> Daftar Akun Baru
      </button>
      
      <div class="text-center">
        <span class="text-muted small">Sudah punya akun? <a href="/auth/login" class="text-info text-decoration-none font-weight-bold">Masuk Sekarang</a></span>
      </div>
    </form>
  </div>
</div>

<%- include('../partials/footer') %>
